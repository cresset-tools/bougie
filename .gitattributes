# Force LF line endings for every text file, regardless of contributors'
# `core.autocrlf` setting. Without this, a Windows checkout normalizes
# committed LF to CRLF on disk and then back to LF on commit, which
# manifests as spurious "LF will be replaced by CRLF" warnings and as
# noisy diffs when CRLF leaks into the index.
* text=auto eol=lf

# Compressed Packagist snapshots used by resolver benchmarks and
# cross-check tests. These are multi-MB binary blobs that change
# only when fixtures are recaptured.
crates/**/tests/fixtures/**/*.zst filter=lfs diff=lfs merge=lfs -text
